# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/tierlist"

# JWT Secrets (gere chaves aleatórias com 64+ caracteres)
JWT_SECRET="gere-uma-chave-aleatoria-64-chars"
JWT_REFRESH_SECRET="outra-chave-aleatoria-64-chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Cloudinary (para upload de imagens)
CLOUDINARY_CLOUD_NAME="seu-cloud-name"
CLOUDINARY_API_KEY="sua-api-key"
CLOUDINARY_API_SECRET="seu-api-secret"
CLOUDINARY_UPLOAD_PRESET="tierlist_unsigned"

# Environment
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:3000"

# Cookies
COOKIE_SECRET="outra-chave-aleatoria-para-cookies"
HOST="0.0.0.0"
