generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tierLists     TierList[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@index([userId])
}

model TierList {
  id          String    @id @default(cuid())
  name        String
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  themeImage  String?
  isPublic    Boolean   @default(true)
  favorite    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  categories  Category[]
  items       TierItem[]
  activities  ActivityLog[]
  @@index([userId])
  @@index([updatedAt])
}

model Category {
  id         String     @id @default(cuid())
  name       String
  color      String
  order      Int
  tierListId String
  tierList   TierList   @relation(fields: [tierListId], references: [id], onDelete: Cascade)
  items      TierItem[]
  @@unique([tierListId, order])
}

model TierItem {
  id         String   @id @default(cuid())
  name       String
  imageUrl   String?
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tierListId String
  tierList   TierList @relation(fields: [tierListId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String
  action    String
  tierListId String
  tierList  TierList @relation(fields: [tierListId], references: [id], onDelete: Cascade)
  timestamp DateTime @default(now())
  @@index([tierListId, timestamp])
}